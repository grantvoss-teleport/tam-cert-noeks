ubuntu@ip-172-49-20-230:~$ REPO="https://raw.githubusercontent.com/tam-cert/tam-cert-noeks/main"
curl -fsSL "$REPO/ansible/roles/teleport/templates/teleport-values.yaml.j2" \
  -o ~/ansible/roles/teleport/templates/teleport-values.yaml.j2

source ~/.teleport-env
DB_PASSWORD=$(aws secretsmanager get-secret-value \
  --secret-id $DB_SECRET_NAME --region us-west-2 \
  --query SecretString --output text)

python3 -c "
with open('/home/ubuntu/ansible/roles/teleport/templates/teleport-values.yaml.j2') as f:
    content = f.read()
content = content.replace('{{ db_password }}', '$DB_PASSWORD')
content = content.replace('{{ rds_address }}', '$RDS_ADDRESS')
content = content.replace('{{ sessions_bucket }}', '$SESSIONS_BUCKET')
with open('/home/ubuntu/teleport-values.yaml', 'w') as f:
    f.write(content)
"

# Verify no duplicates
grep -c "ports:" ~/teleport-values.yaml  # should return 1
cat ~/teleport-values.yaml | grep -A10 "^service:"
2
service:
  spec:
    externalTrafficPolicy: Local
    allocateLoadBalancerNodePorts: true
    healthCheckNodePort: 32444
  ports:
    - name: tls
      port: 443
      targetPort: 3080
      protocol: TCP
      nodePort: 32443
