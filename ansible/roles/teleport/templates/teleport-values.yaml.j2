clusterName: grant-tam-teleport.gvteleport.com

chartMode: standalone

enterprise: true

persistence:
  enabled: false

acme: true
acmeEmail: grant.voss@goteleport.com

proxyListenerMode: multiplex

auth:
  teleportConfig:
    teleport:
      log:
        output: stderr
        severity: INFO
      storage:
        type: postgresql
        conn_string: "postgresql://teleport:{{ db_password }}@{{ rds_address }}:5432/teleport_backend?sslmode=require&pool_max_conns=20"
        audit_events_uri:
          - "postgresql://teleport:{{ db_password }}@{{ rds_address }}:5432/teleport_audit?sslmode=require"
        audit_sessions_uri: "s3://{{ sessions_bucket }}/sessions?region=us-west-2"

    # ── Authentication ────────────────────────────────────────────────────────
    # Primary auth is Okta SAML SSO (set as default connector by teleport-sso
    # role). Local auth is retained for emergency break-glass access only.
    # second_factor: on  — enforces MFA for local users; SAML users satisfy
    # MFA via Okta's own MFA policy.
    auth_service:
      authentication:
        type: saml
        connector_name: okta
        local_auth: true
        second_factor: "on"
        webauthn:
          rp_id: grant-tam-teleport.gvteleport.com

      # ── Machine ID ───────────────────────────────────────────────────────────
      # Enables the GitHub Actions join method so tbot can exchange a GitHub
      # OIDC JWT for a short-lived Teleport certificate without any static
      # secrets. The join token resource (rbac-github-bot-token) is created
      # by the teleport-rbac Ansible bootstrap role and references this config.
      tokens:
        - roles: [Bot]
          join_method: github

proxy:
  teleportConfig:
    teleport:
      log:
        output: stderr
        severity: INFO
    proxy_service:
      https_keypairs_reload_interval: 12h

highAvailability:
  replicaCount: 1
  requireAntiAffinity: false

service:
  spec:
    externalTrafficPolicy: Local
    allocateLoadBalancerNodePorts: true
    healthCheckNodePort: 32444
  ports:
    - name: tls
      port: 443
      targetPort: 3080
      protocol: TCP
      nodePort: 32443
    - name: diag
      port: 3000
      targetPort: 3000
      protocol: TCP