clusterName: grant-tam-teleport.gvteleport.com

chartMode: standalone

enterprise: true

persistence:
  enabled: false

acme: true
acmeEmail: grant.voss@goteleport.com

proxyListenerMode: multiplex

# ── Authentication ─────────────────────────────────────────────────────────────
# Top-level authentication block — used by the Helm chart to set auth_service config.
# Avoids the second_factor / second_factors conflict in Teleport 18.x.
authentication:
  type: saml
  connectorName: okta
  localAuth: true
  secondFactors:
    - otp
    - webauthn
  webauthn:
    rpID: grant-tam-teleport.gvteleport.com

# ── Service (proxy NodePort) ───────────────────────────────────────────────────
# Top-level service key controls the proxy service NodePort.
# The NLB target group forwards port 443 → NodePort 32443.
# healthCheckNodePort 32444 returns 200 only on the node running the proxy pod
# (externalTrafficPolicy: Local), telling the NLB which node is active.
service:
  type: NodePort
  nodePort: 32443
  externalTrafficPolicy: Local

# ── Auth service config ────────────────────────────────────────────────────────
auth:
  teleportConfig:
    teleport:
      log:
        output: stderr
        severity: INFO
      storage:
        type: postgresql
        # In-cluster PostgreSQL pod — cert authentication, no password.
        # CN of client cert matches PostgreSQL username 'teleport'.
        # pg_hba.conf enforces: hostssl ... teleport ... cert clientcert=verify-full
        conn_string: "postgresql://teleport@postgres-service.postgres.svc.cluster.local:5432/teleport_backend?sslmode=verify-full&sslcert=/pg-certs/client.crt&sslkey=/pg-certs/client.key&sslrootcert=/pg-certs/ca.crt&pool_max_conns=20"
        audit_events_uri:
          - "postgresql://teleport@postgres-service.postgres.svc.cluster.local:5432/teleport_audit?sslmode=verify-full&sslcert=/pg-certs/client.crt&sslkey=/pg-certs/client.key&sslrootcert=/pg-certs/ca.crt"
        audit_sessions_uri: "s3://{{ sessions_bucket }}/sessions?region=us-west-2"

  # Mount the client certs Secret into the auth pod
  extraVolumes:
    - name: pg-client-certs
      secret:
        secretName: teleport-pg-client-certs
        defaultMode: 0600

  extraVolumeMounts:
    - name: pg-client-certs
      mountPath: /pg-certs
      readOnly: true

proxy:
  teleportConfig:
    teleport:
      log:
        output: stderr
        severity: INFO
    proxy_service:
      https_keypairs_reload_interval: 12h

highAvailability:
  replicaCount: 1
  requireAntiAffinity: false
