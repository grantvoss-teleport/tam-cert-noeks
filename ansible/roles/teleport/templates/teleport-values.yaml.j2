clusterName: grant-tam-teleport.gvteleport.com

chartMode: standalone

enterprise: true

persistence:
  enabled: false

acme: true
acmeEmail: grant.voss@goteleport.com

proxyListenerMode: multiplex

auth:
  teleportConfig:
    teleport:
      log:
        output: stderr
        severity: INFO
      storage:
        type: postgresql
        # IAM authentication — no password in the connection string.
        # Teleport uses the EC2 instance IAM role to obtain a short-lived
        # RDS auth token. The 'teleport' DB user must have rds_iam granted.
        conn_string: "postgresql://teleport@{{ rds_address }}:5432/teleport_backend?sslmode=require&pool_max_conns=20"
        audit_events_uri:
          - "postgresql://teleport@{{ rds_address }}:5432/teleport_audit?sslmode=require"
        audit_sessions_uri: "s3://{{ sessions_bucket }}/sessions?region=us-west-2"

    auth_service:
      # Primary auth is Okta SAML SSO. Local auth retained for break-glass only.
      authentication:
        type: saml
        connector_name: okta
        local_auth: true
        second_factor: "on"
        webauthn:
          rp_id: grant-tam-teleport.gvteleport.com
      # Enables the GitHub Actions join method for the Machine ID RBAC bot.
      tokens:
        - roles: [Bot]
          join_method: github

proxy:
  teleportConfig:
    teleport:
      log:
        output: stderr
        severity: INFO
    proxy_service:
      https_keypairs_reload_interval: 12h

highAvailability:
  replicaCount: 1
  requireAntiAffinity: false

service:
  spec:
    externalTrafficPolicy: Local
    allocateLoadBalancerNodePorts: true
    healthCheckNodePort: 32444
  ports:
    - name: tls
      port: 443
      targetPort: 3080
      protocol: TCP
      nodePort: 32443
    - name: diag
      port: 3000
      targetPort: 3000
      protocol: TCP
