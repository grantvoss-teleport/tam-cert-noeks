clusterName: grant-tam-teleport.gvteleport.com

chartMode: standalone

enterprise: true

persistence:
  enabled: false

acme: true
acmeEmail: grant.voss@goteleport.com

proxyListenerMode: multiplex

auth:
  teleportConfig:
    teleport:
      log:
        output: stderr
        severity: INFO
      storage:
        # ── PostgreSQL backend (in-cluster pod) ───────────────────────────────
        # Connection strings and TLS cert paths will be added here once the
        # postgres pod config is supplied.
        type: postgresql
        conn_string: ""
        audit_events_uri:
          - ""
        audit_sessions_uri: "s3://{{ sessions_bucket }}/sessions?region=us-west-2"

    auth_service:
      authentication:
        type: saml
        connector_name: okta
        local_auth: true
        second_factor: "on"
        webauthn:
          rp_id: grant-tam-teleport.gvteleport.com

proxy:
  teleportConfig:
    teleport:
      log:
        output: stderr
        severity: INFO
    proxy_service:
      https_keypairs_reload_interval: 12h

highAvailability:
  replicaCount: 1
  requireAntiAffinity: false

service:
  spec:
    externalTrafficPolicy: Local
    allocateLoadBalancerNodePorts: true
    healthCheckNodePort: 32444
  ports:
    - name: tls
      port: 443
      targetPort: 3080
      protocol: TCP
      nodePort: 32443
    - name: diag
      port: 3000
      targetPort: 3000
      protocol: TCP
