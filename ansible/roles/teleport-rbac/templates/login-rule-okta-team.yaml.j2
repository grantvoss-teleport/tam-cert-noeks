kind: login_rule
version: v1
metadata:
  name: okta-team-trait
  description: "Maps Okta groups attribute to internal.team trait for namespace/node scoping"
spec:
  priority: 0
  traits_map:
    # Passes through all existing traits unchanged
    logins:
      - external.logins
    # Preserves groups so SAML attributes_to_roles mapping still works after
    # the login rule runs (traits_map replaces all traits — groups must be
    # explicitly forwarded or the connector role mapping has nothing to match).
    groups:
      - external.groups
    # Maps the Okta 'groups' attribute directly to internal.team
    # Okta group name must match the target K8s namespace and EC2 node 'team' label exactly.
    # e.g. Okta group 'okta-teleport-users' → internal.team = ['okta-teleport-users']
    #      → okta_kube scoped to namespace 'okta-teleport-users'
    #      → okta_ssh scoped to nodes with label team=okta-teleport-users
    team:
      - external.groups
